#~ msgid "Description delay (ms, 0=instant):"
#~ msgstr "Açıklama gecikmesi (ms, 0=anında):"

#~ msgid ""
#~ "Number of milliseconds to wait before announcing the character "
#~ "description. Set to 0 to announce the description immediately instead of "
#~ "the character."
#~ msgstr ""
#~ "Karakter açıklamasının kaç milisaniye sonra seslendirilceğini belirler. 0 "
